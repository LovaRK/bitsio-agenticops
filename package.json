{
  "name": "bitsio-telemetry-agent",
  "version": "0.1.0",
  "private": true,
  "description": "BitsIO Telemetry Value Agent - Local-first AI observability platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker compose up",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --port 8001",
    "dev:web": "cd apps/web && npm run dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
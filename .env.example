# Database
DATABASE_URL=postgresql+asyncpg://bitsio:bitsio_dev_password@localhost:5432/telemetry_agent

# Redis
REDIS_URL=redis://localhost:6379

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL_PROVIDER=ollama
DEFAULT_MODEL_NAME=gemma:2b

# Splunk Configuration
SPLUNK_URL=https://localhost:8089
SPLUNK_TOKEN=your_splunk_token_here
SPLUNK_ADAPTER_MODE=mcp

# AI Providers (optional - leave empty for local-only)
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Runtime Configuration
LOCAL_MODE=true
ENV=development

# Security
API_KEY=dev-api-key-change-in-production
# Runtime
ENV=dev
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8001
WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001
INTERNAL_API_BASE_URL=http://localhost:8001
NEXT_PUBLIC_USE_MOCK=false
NEXT_PUBLIC_REQUIRE_LIVE_API=false
# When false (default), core tabs (dashboard/incidents/approvals/monitoring/telemetry)
# fail fast instead of silently using mock fallback.
NEXT_PUBLIC_MAIN_TABS_ALLOW_FALLBACK=false
# Server-side only (not exposed to browser)
DEV_ANALYST_KEY=dev-analyst

# Splunk MCP
SPLUNK_MCP_BASE_URL=http://mock-mcp:8081
SPLUNK_MCP_TOKEN=
SPLUNK_MCP_ROLE=read_only
SPLUNK_ADAPTER_MODE=auto
SPLUNK_AUTH_SCHEME=Bearer
SPLUNK_LIVE_MODE=false
SPLUNK_WEB_BASE_URL=http://localhost:8000
SPLUNK_MCP_SSL_VERIFY=true

# LLM
MODEL_PROVIDER=ollama
ANTHROPIC_API_KEY=
MODEL_NAME=qwen2.5:14b
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Postgres
POSTGRES_USER=bitsio
POSTGRES_PASSWORD=bitsio
POSTGRES_DB=bitsio_agenticops
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://bitsio:bitsio@postgres:5432/bitsio_agenticops

# Redis
REDIS_URL=redis://redis:6379/0

# Telemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=agent-runtime
TENANT_SAFE_ID=tenant_demo

# Security
OIDC_ISSUER=
OIDC_AUDIENCE=
VAULT_ADDR=
VAULT_TOKEN=
